---
interface Props {
  code: string;
  label: string;
  title: string;
  note?: string;
  inverse?: boolean;
}

const { code, label, title, note, inverse = false } = Astro.props;
---

<div class:list={['section-heading', { 'section-heading--inverse': inverse }]} data-reveal>
  <div class="section-heading__eyebrow">
    <span>{code}</span>
    <span>{label}</span>
  </div>
  <h2>{title}</h2>
  {note && <p>{note}</p>}
</div>
